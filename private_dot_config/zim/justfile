# Zim framework management

set shell := ["nu", "-c"]

# Default: update modules
default: update

# Install Zim
install:
    curl -fsSL https://raw.githubusercontent.com/zimfw/install/master/install.zsh | zsh

# Update Zim modules
update:
    zimfw update

# Uninstall Zim modules
uninstall:
    zimfw uninstall

# Upgrade Zim itself
upgrade:
    zimfw upgrade

# Clean Zim cache and compiled files
clean:
    zimfw clean
    zimfw clean-compiled

# Compile Zim modules for faster loading
compile:
    zimfw compile

# Clean and recompile all Zim modules
recompile:
    #!/usr/bin/env nu
    print "🧹 Cleaning compiled files..."
    zimfw clean-compiled
    print "🔨 Recompiling modules..."
    zimfw compile
    print "✅ Recompilation complete"

# List installed modules
list:
    zimfw list

# Show Zim version
version:
    zimfw version

# Build custom completions
completions:
    #!/usr/bin/env nu
    print "Regenerating custom completions..."
    let modules = (glob "modules/*/init.zsh")
    for module in $modules {
        print $"Processing ($module)..."
        zsh -c $"source ($module)"
    }

# Doctor: report only problems
doctor:
    #!/usr/bin/env nu
    mut issues = []
    let zim_dir = ("~/.zim" | path expand)
    if not ($zim_dir | path exists) { $issues = ($issues | append "zim not installed — run: curl -fsSL https://raw.githubusercontent.com/zimfw/install/master/install.zsh | zsh") }
    let zimrc = ("~/.config/zim/zimrc" | path expand)
    if not ($zimrc | path exists) { $issues = ($issues | append "zimrc missing — run: chezmoi apply") }
    if ($zim_dir | path exists) {
        let modules_dir = ($zim_dir | path join "modules")
        if not ($modules_dir | path exists) or (ls $modules_dir | is-empty) {
            $issues = ($issues | append "no modules — run: zsh -c 'source ~/.zim/zimfw.zsh && zimfw install'")
        }
    }
    if ($issues | is-empty) { return }
    print "zim:"
    $issues | each {|i| print $"  ($i)" } | ignore
    exit 1
