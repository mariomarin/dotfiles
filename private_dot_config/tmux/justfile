# Tmux configuration management
# Plugins managed by nix (see nix/common/modules/cli-tools.nix)

set shell := ["nu", "-c"]

# Default: reload config
default: reload

# Reload tmux configuration
reload:
    tmux source-file ~/.config/tmux/tmux.conf ; tmux display-message "Config reloaded!"

# Show tmux status
status:
    #!/usr/bin/env nu
    let sessions = (do { tmux list-sessions } | complete)
    if $sessions.exit_code != 0 {
        print "No tmux sessions running"
    } else {
        print $sessions.stdout
        (do { tmux list-windows } | complete | get stdout)
        (do { tmux list-panes } | complete | get stdout)
    }

# Kill tmux server
kill-server:
    tmux kill-server

# Doctor: report only problems
doctor:
    #!/usr/bin/env nu
    mut issues = []
    let tmux = (do { ^tmux -V } | complete)
    if $tmux.exit_code != 0 { $issues = ($issues | append "tmux not found — install tmux") }
    let config = ("~/.config/tmux/tmux.conf" | path expand)
    if not ($config | path exists) { $issues = ($issues | append "config missing — run: chezmoi apply") }
    let plugins_dir = ("~/.local/share/tmux/plugins" | path expand)
    if not ($plugins_dir | path exists) { $issues = ($issues | append "plugins missing — run: chezmoi apply") }
    if ($issues | is-empty) { return }
    print "tmux:"
    $issues | each {|i| print $"  ($i)" } | ignore
    exit 1
