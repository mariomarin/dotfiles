#:schema https://docs.jj-vcs.dev/latest/config-schema.json

[user]
name = "{{ output "git" "config" "user.name" | trim }}"
email = "{{ output "git" "config" "user.email" | trim }}"

[ui]
pager = ":builtin"
diff-formatter = ":git"

[aliases]
s = ["show", "--git"]
f = ["git", "fetch", "--tracked"]
p = ["git", "push", "--tracked"]

# Pre-commit integration
pre-check = ["util", "exec", "--", "jj-pre-push.nu", "check"]
push-check = ["util", "exec", "--", "jj-pre-push.nu", "push"]

# Common shortcuts
st = ["status"]
l = ["log"]
d = ["diff"]
n = ["new"]
e = ["edit"]
a = ["abandon"]
sq = ["squash"]
ds = ["describe"]

# Show current change
current = ["log", "--no-graph", "-r", "@", "-T", "change_id.shortest(8) ++ ' ' ++ description.first_line()"]

# Log aliases
ll = ["log", "-r", "::@"]
la = ["log", "-r", "all()"]
recent = ["log", "-r", "::@", "-n", "10"]

# Branch management
bm = ["bookmark"]
bml = ["bookmark", "list"]
bmc = ["bookmark", "create"]
bmf = ["bookmark", "forget"]

# Show files in current change
files = ["diff", "--summary"]

# Quick commit
qc = ["describe", "-m"]

# Rebase shortcuts
rb = ["rebase"]
rbd = ["rebase", "-d"]
rbs = ["rebase", "-s"]

# Git integration
gf = ["git", "fetch"]
gp = ["git", "push"]

# DO NOT enable just-fmt here — it wipes justfiles when run outside their
# directory because --justfile=$path can't resolve imports. Use prek hook instead.
# [fix.tools.just-fmt]
# command = ["just", "--fmt", "--unstable", "--justfile=$path"]
# patterns = ["glob:'**/justfile'"]

[fix.tools.nixpkgs-fmt]
command = ["nixpkgs-fmt"]
patterns = ["glob:'**/*.nix'"]

[fix.tools.shfmt]
command = ["shfmt", "-i", "2", "-ci", "-sr", "-kp", "$path"]
patterns = ["glob:'**/*.sh'"]

[fix.tools.stylua]
command = ["stylua", "-"]
patterns = ["glob:'**/*.lua'"]

[fix.tools.yamlfmt]
command = ["yamlfmt", "-in"]
patterns = ["glob:'**/*.yaml'", "glob:'**/*.yml'"]
