# Chezmoi operations

set shell := ["nu", "-c"]

# Load .env.local from parent directory (repository root)
set dotenv-filename := "../.env.local"
set dotenv-load

# Default target
default: apply

# Apply dotfiles changes
apply:
    chezmoi apply --no-tty

# Show what would change
diff:
    chezmoi diff

# Quick apply without updates
quick-apply:
    CHEZMOI_SKIP_UPDATES=1 chezmoi apply --no-tty

# Initialize chezmoi with repository
init REPO="git@github.com:mariomarin/dotfiles.git":
    chezmoi init {{ REPO }} --apply

# Install chezmoi
install:
    curl -sfL https://git.io/chezmoi | sh

# Show status
status:
    chezmoi status

# Add a file to chezmoi
add FILE:
    chezmoi add {{ FILE }}

# Edit a managed file
edit FILE:
    chezmoi edit {{ FILE }}

# Update from repository
update:
    chezmoi git pull -- --rebase && chezmoi diff

# Health check
doctor:
    #!/usr/bin/env nu
    mut issues = []
    let cm = (do { ^chezmoi --version } | complete)
    if $cm.exit_code != 0 { $issues = ($issues | append "chezmoi not found — install chezmoi"); print "chezmoi:"; $issues | each {|i| print $"  ($i)" } | ignore; exit 1 }
    let config = ("~/.config/chezmoi/chezmoi.toml" | path expand)
    if not ($config | path exists) { $issues = ($issues | append "config missing — run: chezmoi init") }
    let status = (do { ^chezmoi status } | complete)
    if $status.exit_code == 0 and ($status.stdout | str trim | is-not-empty) {
        let count = ($status.stdout | lines | length)
        $issues = ($issues | append $"($count) files out of sync — run: chezmoi apply")
    }
    if ($issues | is-empty) { return }
    print "chezmoi:"
    $issues | each {|i| print $"  ($i)" } | ignore
    exit 1
