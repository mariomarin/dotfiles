#!/usr/bin/env nu
# j - jj workflow helper (git-branchless ergonomics for jujutsu)

def parse-bookmark-lines []: list<string> -> list<record<value: string, description: string>> {
  $in
  | where {|l| not ($l | is-empty) }
  | each {|b| { value: $b, description: "bookmark" } }
}

def parse-revision-lines []: list<string> -> list<record<value: string, description: string>> {
  $in
  | where {|l| not ($l | is-empty) }
  | each {|l|
    let parts = ($l | split row " " --number 2)
    { value: ($parts | first), description: ($parts | skip 1 | str join " " | default "") }
  }
}

def run-or-fail [label: string, cmd: closure] {
  let result = (do $cmd | complete)
  if $result.exit_code != 0 {
    if ($result.stdout | is-not-empty) { print -e $result.stdout }
    if ($result.stderr | is-not-empty) { print -e $result.stderr }
    error make { msg: $"($label) failed" }
  }
  $result
}

def "nu-complete j bookmarks" [] {
  ^jj bookmark list -T 'name ++ "\n"' err> /dev/null | lines | parse-bookmark-lines
}

def "nu-complete j revisions" [] {
  ^jj log --no-graph -T 'change_id.short() ++ " " ++ description.first_line() ++ "\n"' --limit 20 err> /dev/null
  | lines | parse-revision-lines
}

# Resolve bookmark from current/parent state — returns record with result or error
def resolve-bookmark [current: string, is_empty_commit: bool, parent: string] {
  if not ($current | is-empty) { return { ok: true, value: $current } }
  if not $is_empty_commit { return { ok: false, error: "No bookmark found for @ (commit has changes)" } }
  if not ($parent | is-empty) { return { ok: true, value: $parent } }
  { ok: false, error: "No bookmark found for @ or @-" }
}

def get-current-bookmark [] {
  let current = (^jj log -r @ --no-graph -T 'bookmarks' err> /dev/null | str trim)
  let is_empty_commit = (^jj log -r @ --no-graph -T 'if(empty, "true", "")' err> /dev/null | str trim) == "true"
  let parent = (^jj log -r '@-' --no-graph -T 'bookmarks' err> /dev/null | str trim)

  let result = (resolve-bookmark $current $is_empty_commit $parent)
  if $result.ok { $result.value } else { error make { msg: $result.error } }
}

# Revset for all local work above a base
def revset-local [base: string] {
  $"roots\(($base)..mutable\(\)\)"
}

# Sync with remote: fetch + rebase all local work onto trunk
def "main sync" [
  bookmark?: string@"nu-complete j bookmarks"  # Sync specific bookmark only
  --no-pull                                     # Skip fetching from remote
  --current (-c)                                # Sync only current change (@)
  --mine (-m)                                   # Sync only my commits
  --base (-b): string = "trunk()"              # Base bookmark/revset
] {
  if not $no_pull {
    run-or-fail "Fetch" { ^jj git fetch --all-remotes }
  }

  # Remove stale jj-spr tracking branches
  let has_spr = (do { ^jj config get --repo spr.githubRepository } | complete)
  if $has_spr.exit_code == 0 and not ($has_spr.stdout | str trim | is-empty) {
    let spr_branches = (do { ^git branch -r } | complete)
    if $spr_branches.exit_code == 0 {
      $spr_branches.stdout | lines
      | str trim
      | where {|b| $b | str starts-with "origin/spr/" }
      | each {|b| do { ^git branch -rD $b } | complete; null }
      | ignore

      do { ^jj git import } | complete | ignore
    }
  }

  if ($bookmark | is-not-empty) {
    run-or-fail "Rebase" { ^jj rebase -b $bookmark -d $base }
    return
  }

  if $current {
    run-or-fail "Rebase" { ^jj rebase -d $base }
    return
  }

  let revset = if $mine {
    $"roots\(($base)..mine\(\)\)"
  } else {
    $"roots\(($base)..mutable\(\)\)"
  }

  run-or-fail "Rebase" { ^jj rebase -s $revset -d $base }
  ^jj abandon $"($base)..mutable\(\) & empty\(\) & ~@" err> /dev/null

  let conflicted = (^jj log -r $"($base)..mutable\(\) & conflicts\(\)" --no-graph -T 'change_id.short() ++ "\n"' err> /dev/null | lines | where {|l| not ($l | is-empty) })

  if ($conflicted | length) > 0 {
    print -e $"($conflicted | length) conflict\(s\):"
    ^jj log -r ($conflicted | str join " | ")
  }
}

# Land PR via jj-spr and sync
def "main land" [
  revision?: string@"nu-complete j revisions"  # Revision to land (default: @-)
  --rev (-r): string                            # Revision to land (flag form, compat)
] {
  if ($rev | is-not-empty) and ($revision | is-not-empty) {
    error make { msg: "ambiguous: provide either positional revision or -r, not both" }
  }
  let rev = ($rev | default ($revision | default "@-"))
  let result = (run-or-fail "Land" { ^jj-spr land -r $rev })
  if ($result.stdout | is-not-empty) { print $result.stdout }
  main sync
}

# Create or update PR from bookmark
def "main pr" [
  bookmark?: string@"nu-complete j bookmarks"  # Bookmark to push (default: current)
  --create (-c)                                 # Create new PR
  --draft (-d)                                  # Create as draft
  --all (-a)                                    # Process all bookmarks
  ...extra: string                              # Extra args passed to gh pr create
] {
  let bookmarks = if $all {
    ^jj bookmark list -T 'name ++ "\n"' err> /dev/null | lines | where {|l| not ($l | is-empty) }
  } else if ($bookmark | is-not-empty) {
    [$bookmark]
  } else {
    [(get-current-bookmark)]
  }

  let failures = ($bookmarks | each {|bm|
    let pr_number = (do { ^gh pr list --head $bm --json number --jq '.[0].number' } | complete)
    let pr_num = ($pr_number.stdout | str trim)

    if not ($pr_num | is-empty) and $pr_number.exit_code == 0 {
      let push = (do { ^jj git push --bookmark $bm --force } | complete)
      if $push.exit_code != 0 {
        print -e $"($bm): ($push.stderr)"
        return $bm
      }
      if ($push.stdout | is-not-empty) { print $push.stdout }
      return null
    }

    if not $create {
      print -e $"($bm): no PR found, use --create"
      return $bm
    }

    let gh_args = (["pr" "create" "--head" $bm "--fill"]
      | if $draft { append "--draft" } else { $in }
      | if not ($extra | is-empty) { append $extra } else { $in })
    let create_result = (do { ^gh ...$gh_args } | complete)
    if $create_result.exit_code != 0 {
      print -e $"($bm): ($create_result.stderr)"
      return $bm
    }
    if ($create_result.stdout | is-not-empty) { print $create_result.stdout }
    null
  } | where {|it| $it != null })

  if not ($failures | is-empty) {
    error make { msg: $"failed for: ($failures | str join ', ')" }
  }
}

# Move commits (git-branchless style)
def "main move" [
  commit: string@"nu-complete j revisions"      # Commit to move
  dest: string@"nu-complete j revisions"        # Destination
  --revisions (-r)                              # Move single commit only (default: with descendants)
  --source (-s)                                 # Move with descendants (default, explicit)
  --exact (-x)                                  # Alias for -r
] {
  if ($revisions or $exact) and $source {
    error make { msg: "ambiguous: -r/-x and -s are mutually exclusive" }
  }
  let mode = if $revisions or $exact { "-r" } else { "-s" }
  run-or-fail "Move" { ^jj rebase $mode $commit -d $dest }
}

# Push bookmark via jj-hp (runs hooks, then pushes)
def "main push" [
  bookmark?: string@"nu-complete j bookmarks"  # Bookmark to push (default: current)
  --force (-f)                                  # Force push (skips hooks)
] {
  let bm = if ($bookmark | is-not-empty) { $bookmark } else { get-current-bookmark }
  let result = if $force {
    run-or-fail "Push" { ^jj git push --bookmark $bm --force }
  } else {
    run-or-fail "Push" { ^jj-hp push --bookmark $bm }
  }
  if ($result.stdout | is-not-empty) { print $result.stdout }
}

# Set main bookmark and push via jj-hp
def "main push-main" [] {
  run-or-fail "Bookmark set" { ^jj bookmark set main }
  let result = (run-or-fail "Push" { ^jj-hp push --bookmark main })
  if ($result.stdout | is-not-empty) { print $result.stdout }
}

# Push directly via jj git push (no hooks)
def "main gp" [
  bookmark?: string@"nu-complete j bookmarks"  # Bookmark to push (default: current)
  --force (-f)                                  # Force push
  --tracked (-t)                                # Push all tracked bookmarks
] {
  let args = if $tracked {
    ["--tracked"]
  } else {
    let bm = if ($bookmark | is-not-empty) { $bookmark } else { get-current-bookmark }
    if $force { ["--bookmark" $bm "--force"] } else { ["--bookmark" $bm] }
  }
  run-or-fail "Push" { ^jj git push ...$args }
}

# Run hooks on current change then jj-spr diff
def "main spr" [
  --all (-a)          # Process all bookmarks (jj-spr diff --all)
  --skip-hooks        # Skip jj-hp run, go straight to jj-spr diff
] {
  if not $skip_hooks {
    run-or-fail "Hooks" { ^jj-hp run @ }
  }
  let result = (do { if $all { ^jj-spr diff --all } else { ^jj-spr diff } } | complete)
  if ($result.stdout | is-not-empty) { print $result.stdout }
  if $result.exit_code != 0 {
    if ($result.stderr | is-not-empty) { print -e $result.stderr }
    exit $result.exit_code
  }
}

# Interactive bookmark checkout (requires fzf)
def "main co" [] {
  let selection = (^jj bookmark list | ^fzf --height=20 --reverse | str trim)
  if ($selection | is-empty) { return }

  let bookmark = ($selection | split row " " | first | str replace -r ':$' '')
  ^jj new $bookmark
}

# Abandon empty commits with no description
def "main clean" [
  scope?: string  # Revset scope (default: mutable())
] {
  let s = ($scope | default "mutable()")

  let empty_commits = (
    ^jj log -r $"($s) & empty\(\)" --no-graph -T 'if(description, "", change_id.short() ++ "\n")' err> /dev/null
    | lines
    | where {|l| not ($l | is-empty) }
  )

  if ($empty_commits | is-empty) { return }

  $empty_commits | each {|c| print $"  ($c)" } | ignore

  let answer = (input "Abandon these commits? [y/N] ")
  if ($answer | str downcase) != "y" { return }

  ^jj abandon ...$empty_commits
}

# Show help
def "main help" [] {
  print "j - jj workflow helper (git-branchless ergonomics)

Subcommands:
  j sync [bookmark]      Sync local work with trunk (fetch + rebase)
  j land [revision]      Land PR via jj-spr and sync
  j pr [bookmark]        Create or update PR (-c to create, -d for draft)
  j move <commit> <dest> Move commits (-r for single commit)
  j push [bookmark]      Push via jj-hp (runs hooks, then pushes)
  j push-main            Set main bookmark and push via jj-hp
  j gp [bookmark]        Push directly via jj git push (no hooks)
  j spr                  Run hooks then jj-spr diff
  j co                   Interactive bookmark checkout (fzf)
  j clean [scope]        Abandon empty undescribed commits

Flags:
  j sync --no-pull       Skip fetch
  j sync -c              Sync only current change
  j sync -m              Sync only my commits
  j sync -b <base>       Custom base (default: trunk())
  j land -r <rev>        Land specific revision
  j pr -c                Create new PR
  j pr -d                Create as draft
  j pr -a                Process all bookmarks
  j pr -c -- --title \"...\" --body \"...\"  Pass extra gh args after --
  j push -f              Force push (skips hooks)
  j gp -t                Push all tracked bookmarks
  j spr -a               Process all bookmarks (jj-spr diff --all)
  j spr --skip-hooks     Skip hooks, go straight to jj-spr diff
  j move -r              Move single commit (not descendants)
  j move -x              Alias for -r"
}

def main [] {
  main help
}
