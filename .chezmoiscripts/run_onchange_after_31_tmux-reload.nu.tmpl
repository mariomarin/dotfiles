#!/usr/bin/env nu
# Reload tmux config when any tmux config file changes
{{- $tmuxReloadFiles := list
  "private_dot_config/tmux/tmux.conf"
  "private_dot_config/tmux/settings.tmux"
  "private_dot_config/tmux/plugins.tmux"
  "private_dot_config/tmux/mappings/root.tmux"
  "private_dot_config/tmux/mappings/prefix.tmux"
  "private_dot_config/tmux/mappings/copy-mode-vi.tmux"
-}}
{{- range $file := $tmuxReloadFiles }}
# {{ $file }} hash: {{ include $file | sha256sum }}
{{- end }}

if (which tmux | is-empty) { exit 0 }

let server_check = (do { ^tmux list-sessions } | complete)
if $server_check.exit_code != 0 {
    print "tmux reload skipped (server not running)"
    exit 0
}

let result = (do { ^tmux source-file ~/.config/tmux/tmux.conf } | complete)
if $result.exit_code == 0 {
    print "tmux config reloaded"
} else {
    print $"tmux reload failed: ($result.stderr)"
    exit 1
}
