# macOS-only configurations (ignore on non-macOS)
{{ if ne .chezmoi.os "darwin" }}
nix/darwin
nix/darwin/**
{{ end }}

# Linux-only window managers (ignore on macOS)
{{ if eq .chezmoi.os "darwin" }}
